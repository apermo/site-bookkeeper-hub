{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Site Bookkeeper Hub - Network Report Payload",
	"description": "JSON Schema for the POST /network-report request body.",
	"type": "object",
	"required": ["schema_version", "timestamp", "main_site_url"],
	"properties": {
		"schema_version": {
			"type": "integer",
			"minimum": 1,
			"description": "Schema version of this payload."
		},
		"timestamp": {
			"type": "string",
			"format": "date-time",
			"description": "ISO 8601 timestamp of when the report was generated."
		},
		"main_site_url": {
			"type": "string",
			"format": "uri",
			"description": "The main site URL of the WordPress Multisite network."
		},
		"subsites": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["blog_id", "url", "label"],
				"properties": {
					"blog_id": {
						"type": "integer",
						"description": "WordPress blog ID."
					},
					"url": {
						"type": "string",
						"format": "uri",
						"description": "Subsite URL."
					},
					"label": {
						"type": "string",
						"description": "Subsite display name."
					}
				},
				"additionalProperties": true
			}
		},
		"network_plugins": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["slug", "name", "version"],
				"properties": {
					"slug": {
						"type": "string",
						"description": "Plugin slug."
					},
					"name": {
						"type": "string",
						"description": "Plugin display name."
					},
					"version": {
						"type": "string",
						"description": "Currently installed version."
					},
					"update_available": {
						"type": ["string", "null"],
						"description": "Available update version, or null."
					}
				},
				"additionalProperties": true
			}
		},
		"super_admins": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["user_login", "display_name", "email"],
				"properties": {
					"user_login": {
						"type": "string",
						"description": "WordPress username."
					},
					"display_name": {
						"type": "string",
						"description": "Display name."
					},
					"email": {
						"type": "string",
						"format": "email",
						"description": "User email address."
					}
				},
				"additionalProperties": true
			}
		},
		"network_settings": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["key", "label", "value"],
				"properties": {
					"key": {
						"type": "string",
						"description": "Setting machine-readable key."
					},
					"label": {
						"type": "string",
						"description": "Setting human-readable label."
					},
					"value": {
						"type": "string",
						"description": "Setting value."
					}
				},
				"additionalProperties": true
			}
		}
	},
	"additionalProperties": true
}
